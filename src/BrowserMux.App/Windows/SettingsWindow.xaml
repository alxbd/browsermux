<Window
    x:Class="BrowserMux.App.Windows.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:BrowserMux.App.ViewModels"
    Title="BrowserMux Settings">

    <NavigationView x:Name="NavView"
                    PaneDisplayMode="Left"
                    IsBackButtonVisible="Collapsed"
                    IsSettingsVisible="False"
                    SelectionChanged="NavView_SelectionChanged"
                    OpenPaneLength="180">
        <NavigationView.MenuItems>
            <NavigationViewItem Content="General" Tag="General">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE713;" /></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Browsers" Tag="Browsers">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE774;" /></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Rules" Tag="Rules">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE8FD;" /></NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.MenuItems>
        <NavigationView.FooterMenuItems>
            <NavigationViewItem Content="About" Tag="About">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE946;" /></NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.FooterMenuItems>

        <!-- ═══ Content area ═══ -->
        <ScrollViewer Padding="32,24,32,16">
            <Grid>

            <!-- ─── General ─── -->
            <StackPanel x:Name="GeneralPanel" Spacing="4">
                <TextBlock Text="General Settings" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,0,0,12" />

                <!-- Theme -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="4" Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE771;" Margin="0,0,16,0" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Theme" />
                            <TextBlock Text="Choose light, dark, or system theme" FontSize="12" Opacity="0.5" />
                        </StackPanel>
                        <ComboBox x:Name="ThemeCombo" Grid.Column="2" Width="130" SelectionChanged="ThemeCombo_Changed">
                            <ComboBoxItem Content="System" />
                            <ComboBoxItem Content="Light" />
                            <ComboBoxItem Content="Dark" />
                        </ComboBox>
                    </Grid>
                </Border>

                <!-- Always on top -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="4" Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE8A7;" Margin="0,0,16,0" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Always on top" />
                            <TextBlock Text="Keep picker above other windows" FontSize="12" Opacity="0.5" />
                        </StackPanel>
                        <ToggleSwitch x:Name="AlwaysOnTopToggle" Grid.Column="2" Toggled="AlwaysOnTopToggle_Toggled" MinWidth="0" />
                    </Grid>
                </Border>

                <!-- Close on focus loss -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="4" Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE7E8;" Margin="0,0,16,0" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Close on focus loss" />
                            <TextBlock Text="Hide picker when clicking outside" FontSize="12" Opacity="0.5" />
                        </StackPanel>
                        <ToggleSwitch x:Name="CloseOnFocusLossToggle" Grid.Column="2" Toggled="CloseOnFocusLossToggle_Toggled" MinWidth="0" />
                    </Grid>
                </Border>

                <!-- Detect Chromium profiles -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="4" Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE716;" Margin="0,0,16,0" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Detect Chromium profiles" />
                            <TextBlock Text="Show individual profiles for Chrome, Brave, Edge" FontSize="12" Opacity="0.5" />
                        </StackPanel>
                        <ToggleSwitch x:Name="DetectProfilesToggle" Grid.Column="2" Toggled="DetectProfilesToggle_Toggled" MinWidth="0" />
                    </Grid>
                </Border>

                <!-- Launcher hotkey -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="4" Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE765;" Margin="0,0,16,0" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Launcher hotkey" />
                            <TextBlock Text="Global shortcut to open the picker without a URL" FontSize="12" Opacity="0.5" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                            <TextBox x:Name="HotkeyBox" Width="160" IsReadOnly="True"
                                     PlaceholderText="Click, then press keys"
                                     PreviewKeyDown="HotkeyBox_PreviewKeyDown"
                                     GotFocus="HotkeyBox_GotFocus"
                                     LostFocus="HotkeyBox_LostFocus" />
                            <Button x:Name="HotkeyClearButton" Padding="8,6"
                                    ToolTipService.ToolTip="Clear hotkey"
                                    Click="HotkeyClearButton_Click">
                                <FontIcon Glyph="&#xE711;" FontSize="14" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Set default browser -->
                <TextBlock Text="Other" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,16,0,8" />

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="4" Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE774;" Margin="0,0,16,0" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Default browser" />
                            <TextBlock x:Name="RegistryStatusText" FontSize="12" Opacity="0.5" />
                        </StackPanel>
                        <Button x:Name="SetDefaultButton" Content="Set as default" Grid.Column="2" Click="SetDefaultBrowser_Click" />
                    </Grid>
                </Border>
            </StackPanel>

            <!-- ─── Browsers ─── -->
            <StackPanel x:Name="BrowsersPanel" Spacing="4" Visibility="Collapsed">
                <TextBlock Text="Browsers" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,0,0,12" />

                <ListView x:Name="BrowsersListView" SelectionMode="None"
                          CanReorderItems="True" CanDragItems="True" AllowDrop="True">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="MinHeight" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="4" Padding="16,10" Margin="0,2">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <FontIcon Grid.Column="0" Glyph="&#xE76F;" FontSize="14" Opacity="0.4"
                                              Margin="0,0,12,0" VerticalAlignment="Center"
                                              ToolTipService.ToolTip="Drag to reorder" />

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DisplayName}" />
                                        <TextBlock Text="{Binding ExePath}" FontSize="11" Opacity="0.4" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <Button Grid.Column="2"
                                            Visibility="{Binding RemoveButtonVisibility}"
                                            Click="RemoveCustomBrowser_Click"
                                            ToolTipService.ToolTip="Remove custom browser"
                                            Padding="6" Width="32" Height="32" Margin="0,0,8,0">
                                        <FontIcon Glyph="&#xE74D;" FontSize="12" />
                                    </Button>

                                    <ToggleSwitch Grid.Column="3"
                                                  IsOn="{Binding IsVisible, Mode=TwoWay}"
                                                  OnContent="Show" OffContent="Hide"
                                                  MinWidth="0" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <TextBlock Text="Other" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,16,0,8" />

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="4" Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE72C;" Margin="0,0,16,0" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Rediscover browsers" />
                            <TextBlock Text="Scan registry for newly installed browsers" FontSize="12" Opacity="0.5" />
                        </StackPanel>
                        <Button Content="Refresh" Grid.Column="2" Click="ReloadBrowsers_Click" />
                    </Grid>
                </Border>

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="4" Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE710;" Margin="0,0,16,0" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Add custom browser" />
                            <TextBlock Text="Register an executable not detected automatically" FontSize="12" Opacity="0.5" />
                        </StackPanel>
                        <Button Content="Add..." Grid.Column="2" Click="AddCustomBrowser_Click" />
                    </Grid>
                </Border>
            </StackPanel>

            <!-- ─── Rules ─── -->
            <StackPanel x:Name="RulesPanel" Spacing="4" Visibility="Collapsed">
                <TextBlock Text="Rules" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,0,0,8" />
                <TextBlock FontSize="12" Opacity="0.5" Margin="0,0,0,8" TextWrapping="Wrap"
                           Text="Shift+Click a browser in the picker to auto-create a rule." />

                <ListView x:Name="RulesListView" SelectionMode="None">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="MinHeight" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="4" Padding="12,8" Margin="0,2">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBox Grid.Column="0"
                                             Text="{Binding Pattern, Mode=TwoWay}"
                                             PlaceholderText="domain.com"
                                             FontSize="13" Padding="8,6"
                                             LostFocus="RuleDomain_LostFocus" />

                                    <ComboBox Grid.Column="1"
                                              ItemsSource="{Binding AvailableBrowsers}"
                                              SelectedItem="{Binding SelectedBrowser, Mode=TwoWay}"
                                              DisplayMemberPath="DisplayName"
                                              FontSize="13"
                                              HorizontalAlignment="Stretch"
                                              SelectionChanged="RuleBrowser_Changed" />

                                    <Button Grid.Column="2"
                                            ToolTipService.ToolTip="Delete"
                                            Click="DeleteRule_Click"
                                            Padding="6" Width="36" Height="36">
                                        <FontIcon Glyph="&#xE74D;" FontSize="13" />
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <Button Content="+ Add rule" Margin="0,8,0,0" Click="AddRule_Click" />

                <!-- Test rules -->
                <TextBlock Text="Test Rules" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,20,0,8" />

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="4" Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE768;" Margin="0,0,16,0" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="6">
                            <TextBox x:Name="TestUrlBox" PlaceholderText="https://example.com" FontSize="13" Padding="8,6" />
                            <TextBlock x:Name="TestUrlResult" FontSize="12" Opacity="0.6" />
                        </StackPanel>
                        <Button Content="Test" Grid.Column="2" Click="TestUrl_Click" Margin="12,0,0,0" />
                    </Grid>
                </Border>
            </StackPanel>

            <!-- ─── About ─── -->
            <StackPanel x:Name="AboutPanel" Spacing="4" Visibility="Collapsed">
                <TextBlock Text="About" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,0,0,12" />

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="4" Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE774;" Margin="0,0,16,0" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="BrowserMux" />
                            <TextBlock Text="Modern browser selector for Windows" FontSize="12" Opacity="0.5" />
                        </StackPanel>
                        <TextBlock x:Name="VersionText" Grid.Column="2" VerticalAlignment="Center" Opacity="0.5" />
                    </Grid>
                </Border>

                <!-- Update card -->
                <Border x:Name="UpdateCard" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="4" Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE777;" Margin="0,0,16,0" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="UpdateStatusText" Text="Checking for updates..." FontSize="13" />
                            <ProgressBar x:Name="UpdateProgress" Visibility="Collapsed" IsIndeterminate="False" Minimum="0" Maximum="1" Margin="0,4,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                            <HyperlinkButton x:Name="ReleaseNotesLink" Content="Release notes" Visibility="Collapsed" />
                            <Button x:Name="UpdateButton" Content="Download &amp; install" Visibility="Collapsed" Click="UpdateButton_Click" />
                            <Button x:Name="CheckUpdateButton" Content="Check now" Click="CheckUpdate_Click" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="4" Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE71B;" Margin="0,0,16,0" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Website" />
                            <TextBlock Text="browsermux.com" FontSize="12" Opacity="0.5" />
                        </StackPanel>
                        <HyperlinkButton Content="Open" Grid.Column="2" NavigateUri="https://browsermux.com" />
                    </Grid>
                </Border>

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="4" Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE8A7;" Margin="0,0,16,0" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="GitHub" />
                            <TextBlock Text="alxbd/browsermux" FontSize="12" Opacity="0.5" />
                        </StackPanel>
                        <HyperlinkButton Content="Open" Grid.Column="2" NavigateUri="https://github.com/alxbd/browsermux" />
                    </Grid>
                </Border>
            </StackPanel>

            </Grid>
        </ScrollViewer>
    </NavigationView>
</Window>
