<UserControl
    x:Class="BrowserMux.App.Controls.BrowserCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Height="56">
        <!-- Clickable button fills entire row -->
        <Button x:Name="CardButton"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                HorizontalContentAlignment="Stretch"
                VerticalContentAlignment="Stretch"
                Padding="0"
                Background="Transparent"
                BorderThickness="0"
                CornerRadius="6"
                Click="CardButton_Click"
                RightTapped="CardButton_RightTapped">
            <Button.Resources>
                <ResourceDictionary>
                    <ResourceDictionary.ThemeDictionaries>
                        <ResourceDictionary x:Key="Light">
                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#1F000000" />
                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#33000000" />
                            <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent" />
                            <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="Transparent" />
                        </ResourceDictionary>
                        <ResourceDictionary x:Key="Dark">
                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#26FFFFFF" />
                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#3DFFFFFF" />
                            <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent" />
                            <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="Transparent" />
                        </ResourceDictionary>
                    </ResourceDictionary.ThemeDictionaries>
                </ResourceDictionary>
            </Button.Resources>

            <Button.ContextFlyout>
                <MenuFlyout>
                    <MenuFlyoutItem Text="Open" Click="Open_Click">
                        <MenuFlyoutItem.Icon>
                            <FontIcon Glyph="&#xE8A7;" />
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem Text="Open in private browsing" Click="OpenPrivate_Click">
                        <MenuFlyoutItem.Icon>
                            <FontIcon Glyph="&#xE727;" />
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                </MenuFlyout>
            </Button.ContextFlyout>

            <!-- Row content -->
            <Grid Padding="14,0,12,0" ColumnSpacing="12" VerticalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Icon with optional profile color background -->
                <Border x:Name="ProfileColorDot"
                        Grid.Column="0"
                        Width="46" Height="46"
                        CornerRadius="10"
                        Background="Transparent"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                    <Image x:Name="BrowserIcon"
                           Width="32" Height="32"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center" />
                </Border>

                <!-- Title + subtitle -->
                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center"
                            Spacing="1">
                    <TextBlock x:Name="BrowserName"
                               FontSize="14"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="NoWrap" />
                    <TextBlock x:Name="SubText"
                               FontSize="11"
                               Opacity="0.6"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="NoWrap"
                               Visibility="Collapsed" />
                </StackPanel>

                <!-- Right side: modifier glyphs + shortcut badge -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center">
                    <FontIcon x:Name="PinIcon"
                              Glyph="&#xE718;"
                              FontSize="13"
                              Opacity="0.7"
                              Visibility="Collapsed" />
                    <FontIcon x:Name="IncognitoIcon"
                              Glyph="&#xED1A;"
                              FontSize="13"
                              Opacity="0.7"
                              Visibility="Collapsed" />
                    <Border x:Name="ShortcutBadge"
                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                            CornerRadius="4"
                            Padding="6,1"
                            MinWidth="20"
                            Visibility="Collapsed">
                        <TextBlock FontSize="11"
                                   FontFamily="Consolas, Courier New, monospace"
                                   Opacity="0.75"
                                   TextAlignment="Center">
                            <Run x:Name="ShortcutText" />
                        </TextBlock>
                    </Border>
                </StackPanel>
            </Grid>
        </Button>
    </Grid>
</UserControl>
